# Copy file này thành .env rồi điền giá trị thật vào.
# File .env đã được git-ignore — không bao giờ commit .env.
#
# Usage:
#   cp .env.example .env        (Linux / macOS / WSL2)
#   copy .env.example .env      (Windows CMD)
#   Copy-Item .env.example .env (Windows PowerShell)

# ── FPT Cloud credentials ──────────────────────────────────────────────────
FPTCLOUD_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
FPTCLOUD_API_URL=https://api.fptcloud.com
FPTCLOUD_REGION=HAN-1
FPTCLOUD_TENANT_NAME=quytn13
VPC_ID=<primary-vpc-id>
VPC_IDS=<primary-vpc-id>,<secondary-vpc-id>
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://hc:hc@localhost:5432/hc

# ── Worker tuning (optional) ───────────────────────────────────────────────
HC_WORKER_COUNT=4
HC_REAPER_IDLE_MS=300000
HC_MAX_ATTEMPTS=3
HC_LOG_LEVEL=INFO
