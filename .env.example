# Copy this file to .env and fill in real values.
# .env is git-ignored. Do not commit real credentials.
#
# Windows PowerShell:
#   Copy-Item .env.example .env

# FPT Cloud credentials
FPTCLOUD_TOKEN=
FPTCLOUD_API_URL=https://api.fptcloud.com
FPTCLOUD_REGION=VN/HAN
FPTCLOUD_TENANT_NAME=

# Optional internal/support identifiers. These are diagnostic only unless noted.
HC_TENANT_ID=
HC_REGION_ID=

# VPC configuration
# Prefer HC_VPC_NAME so compute.discover-vpc can resolve data.fptcloud_vpc.this.id.
# Set HC_VPC_ID only when you already know the real provider VPC ID.
HC_VPC_NAME=
HC_VPC_ID=

# Legacy lookup keys. If HC_VPC_ID is empty and HC_VPC_NAME is empty,
# compute.discover-vpc uses VPC_NAME, then VPC_ID, then VPC_IDS[0] as the
# provider lookup key. These are no longer treated as resolved VPC IDs.
VPC_NAME=
VPC_ID=
VPC_IDS=

# Explicit IDs that bypass fragile provider data-source discovery.
HC_STORAGE_POLICY_ID=
HC_SUBNET_ID=

# VM checks. VM and upsize-vm are skipped unless all required values are set.
HC_IMAGE_NAME=
HC_FLAVOR_NAME=
HC_UPSIZE_FLAVOR_NAME=
HC_SSH_KEY=
HC_WINDOWS_2012_IMAGE_NAME=
HC_WINDOWS_2016_IMAGE_NAME=
HC_WINDOWS_2019_IMAGE_NAME=
HC_WINDOWS_2022_IMAGE_NAME=
HC_UBUNTU_1604_IMAGE_NAME=
HC_UBUNTU_1804_IMAGE_NAME=
HC_UBUNTU_2004_IMAGE_NAME=
HC_UBUNTU_2204_IMAGE_NAME=

# Subnet creation defaults.
HC_SUBNET_CIDR=172.26.222.0/24
HC_SUBNET_GATEWAY=172.26.222.1
HC_SUBNET_TYPE=NAT_ROUTED
HC_ADDITIONAL_SUBNET_CIDR=10.136.10.0/24
HC_ADDITIONAL_SUBNET_GATEWAY=10.136.10.1

# Optional disk and security-group settings.
HC_DISK_SIZE_GB=40
HC_DISK_TYPE=EXTERNAL
HC_ADMIN_CIDR=0.0.0.0/0

# Object storage checks. Leave empty to skip instead of failing disabled regions.
HC_ENABLED_OBJECT_REGIONS=

# Worker/runtime tuning
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://hc:hc@localhost:5432/hc
HC_WORKER_COUNT=4
HC_REAPER_IDLE_MS=300000
HC_MAX_ATTEMPTS=3
HC_LOG_LEVEL=INFO

# Terraform debug support
HC_TF_LOG=
HC_TF_LOG_PATH=
