# Copy this file to .env and fill in real values.
# .env is git-ignored. Do not commit real credentials.
#
# Windows PowerShell:
#   Copy-Item .env.example .env

# FPT Cloud credentials.
FPTCLOUD_API_URL=https://api.fptcloud.com
FPTCLOUD_TOKEN=
FPTCLOUD_REGION=VN/HAN
FPTCLOUD_TENANT_NAME=

# Target VPC override.
# Prefer healthcheck.toml [targets].vpcs for the ordered infrastructure list.
# Leave VPC_IDS empty to use healthcheck.toml.
VPC_IDS=

# Queue/runtime.
REDIS_URL=redis://localhost:6379/0

# Additional subnet override.
# Prefer healthcheck.toml [phases."network.additional-subnet"] for CIDR,
# gateway, and known existing CIDRs. Leave these empty to use TOML.
HC_ADDITIONAL_SUBNET_CIDR=
HC_ADDITIONAL_SUBNET_GATEWAY=
HC_EXISTING_SUBNET_CIDRS=

# FPT Cloud S3-compatible object storage.
# S3_REGION is used for SigV4 signing. Bucket creation region belongs in
# healthcheck.toml [phases."object-storage.bucket"].region or enabled_regions.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
